# Комунальний Дворецький environment.
# Copy to .env and fill in.

# --- monobank personal API ---
MONO_TOKEN=your-monobank-personal-x-token
MONO_WEBHOOK_SECRET=long-random-string-used-in-the-webhook-path

# --- Telegram ---
TELEGRAM_BOT_TOKEN=123456:your-bot-token
# The owner: reminders + payment confirmations are sent here.
TELEGRAM_ALLOWED_USER_ID=000000000
# Optional: extra users (family) allowed to talk to the bot — comma-separated IDs.
# The owner is always allowed; these only widen the allowlist (no nudges sent to them).
TELEGRAM_EXTRA_ALLOWED_USER_IDS=

# --- infra ---
DATABASE_URL=sqlite+aiosqlite:///./dvoretskyi.db
REDIS_URL=redis://localhost:6379/0

# --- LLM ---
# claude_code (default) uses the headless Claude Code CLI as a stateless LLM endpoint.
LLM_PROVIDER=claude_code
CLAUDE_BIN=claude
# Model for the text/voice decision turn. Sonnet is fast yet keeps the persona witty;
# empty → the CLI default. Use a snapshot (claude-sonnet-4-6) or the alias "sonnet".
CLAUDE_MODEL=claude-sonnet-4-6
# Vision OCR (meter photos) is slower than a text turn — give it a wider timeout.
CLAUDE_VISION_TIMEOUT_SECONDS=150

# --- matching / misc ---
# Comma-separated MCC codes treated as utility candidates (utilities, telecom,
# 4816 = online/aggregator e.g. Portmone). Aggregator txs prompt but aren't auto-learned.
UTILITY_MCCS=4900,4814,4816
TZ=Europe/Kyiv

# --- pay links (open the relevant iOS app / Portmone; no personal data) ---
# Override only if you have better links. Defaults: monobank & ДАХ App Store pages,
# Portmone mobile top-up.
MONOBANK_PAY_URL=https://apps.apple.com/app/id1287005205
DAH_PAY_URL=https://apps.apple.com/app/id1444141366
MOBILE_PAY_URL=https://www.portmone.com.ua/popovnyty-rakhunok-mobilnoho

# --- Gigabit+ cabinet login (balance scraper, L2) ---
# Login id (doubles as the contract no. for the top-up link) + password for
# cabinet.gigabit.te.ua.
GIGABIT_LOGIN=
GIGABIT_PWD=
# Monthly subscription used to decide "treba platiti" (default 200). Selectors/URLs
# have sane defaults in config.py — override only if the cabinet markup changes.
GIGABIT_MONTHLY_FEE=200

# --- infolviv.com.ua consumer portal (meter readings source, L2) ---
# Account (an email) + password. The «🔢 Мої показники» button reads filed readings
# from here; endpoints/TTL have sane defaults in config.py.
INFOLV_LOGIN=
INFOLV_PWD=
# Live submission to infolviv (setMultipleFactors → POST /counter/factor; body verified).
# Kept as a kill-switch: when false, the submit moment hands back the value for manual
# filing instead of POSTing. Set true to let the bot file readings itself.
INFOLV_SUBMIT_ENABLED=false

# --- households (two properties; addresses are personal data → set on the VPS only) ---
# Code refers to households by slug ("primary"/"secondary"); these are the display names
# (the addresses). Empty → a neutral fallback ("Житло 1"/"Житло 2") is shown.
HOUSEHOLD_PRIMARY_NAME=
HOUSEHOLD_SECONDARY_NAME=
# infolviv invoiceAccount.code that disambiguates the two GAS counters (both properties
# share one login). Set each to that property's GAS account; water self-resolves (it's a
# unique kind, so its own account is found by fallback). Read the codes off the portal.
HOUSEHOLD_PRIMARY_INFOLVIV_ACCOUNT=
HOUSEHOLD_SECONDARY_INFOLVIV_ACCOUNT=
# The secondary property is unoccupied → its gas meter reads a fixed value, filed each
# month. Set the static reading here (e.g. 7952.81); empty → no static meter.
HOUSEHOLD_SECONDARY_STATIC_GAS=

# --- meters (L2, Phase 2) ---
# Per-category submission channel. Default ManualAssistChannel (bot hands back the
# validated value + how to submit; you send it). sms/web_form are opt-in (Phase 2b).
SUBMISSION_CHANNELS=gas:manual,water:manual
# Empty → SmsChannel only emits an sms: deep link; set a URL to POST the 4647 body.
SMS_GATEWAY_URL=
# Downscale a meter photo to this long side (px) before OCR.
OCR_MAX_LONG_SIDE=1600
# Meter-photo archive: keep ONE compressed JPEG per reading so you can pull a meter's
# photo back later («витягни фото газу»). Empty dir → ~/.dvoretskyi/meter_photos (0o700).
METER_PHOTO_DIR=
METER_PHOTO_MAX_LONG_SIDE=1000
METER_PHOTO_QUALITY=55
# Flag a reading whose consumption exceeds k × median(history) (and the absolute cap).
DELTA_SPIKE_K=3
DELTA_ABS_CAP=1000
# Meter readings are due by the last day of the month; start nudging this many days
# before month end (lead time). Seeds Provider.meter_window for gas & water.
METER_WINDOW_DAYS=3
# Submission window: file readings from this day-of-month to month end (28→last day),
# the «найактуальніший» period. Before it the bot holds a photo; the user can force an
# early submit, but only on the Nth «подай раніше» tap (resist twice, file on the 3rd).
METER_SUBMIT_FROM_DAY=28
METER_EARLY_SUBMIT_ATTEMPTS=3

# --- payment reminders ---
# Start nudging this many days before a provider's due_day (daily until paid). Each
# nudge carries a pay link routed by provider type (monobank / ДАХ / Portmone).
PAYMENT_NUDGE_WINDOW_DAYS=5

# --- speech-to-text (voice messages) ---
# Local faster-whisper by default — audio is transcribed on-box and the file is deleted
# right after (never leaves the server). Set STT_PROVIDER=none to ignore voice notes.
STT_PROVIDER=whisper
# Whisper model size: tiny|base|small|medium. `small` is the default — best
# accuracy/size trade-off for Ukrainian on the 2-core VPS. Drop to `base` to save RAM.
WHISPER_MODEL=small
WHISPER_COMPUTE_TYPE=int8
WHISPER_LANGUAGE=uk
STT_TIMEOUT_SECONDS=60

# --- text-to-speech (voice replies to voice asks) ---
# Mirror of STT: a voice question gets a spoken reply, synthesized on-box by Piper (an
# external binary, like CLAUDE_BIN — no extra pip dep). Audio never leaves the server;
# the OGG is sent then deleted. Set TTS_PROVIDER=none to always reply in text.
TTS_PROVIDER=piper
# Path to the piper executable (or just `piper` if it's on PATH).
PIPER_BIN=piper
# Path to the downloaded .onnx voice model (its .json config sits beside it). EMPTY →
# no synth: voice asks still get a text reply, so deploying before the model is fine.
PIPER_VOICE=
# Speaking rate: <1 speeds up, >1 slows down (1.15 dragged, 1.0/0.9/0.8 still read slow).
# 0.75 is brisk and about the floor before clipping. Empty → the voice's own default.
PIPER_LENGTH_SCALE=0.75
# Pause (seconds) after each sentence, so the reply doesn't run together. Empty → ~0.2.
PIPER_SENTENCE_SILENCE=0.2
TTS_TIMEOUT_SECONDS=30
# Replies longer than this many characters are sent as text (too long to voice nicely).
TTS_MAX_CHARS=600
# Stress fix: espeak's uk rules mis-stress some words and NO text trick fixes it (U+0301
# ignored, [[phonemes]] read literally — verified). The only override that reaches Piper is
# an espeak pronunciation dictionary. Run `python scripts/build_espeak_stress.py` on the
# VPS once: it compiles scripts/uk_stress_overrides.txt into ~/.dvoretskyi/espeak-ng-data,
# which the bot auto-detects (no edit needed). Set this only for a non-default data dir.
PIPER_ESPEAK_DATA=

# Public base URL of this service (used by `dvoretskyi register-mono-webhook`).
PUBLIC_BASE_URL=https://example.com

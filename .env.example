# Komunalka / Платон — Phase 1 environment.
# Copy to .env and fill in. NEVER define ANTHROPIC_API_KEY here (see CLAUDE.md / spec §8).

# --- monobank personal API ---
MONO_TOKEN=your-monobank-personal-x-token
MONO_WEBHOOK_SECRET=long-random-string-used-in-the-webhook-path

# --- Telegram ---
TELEGRAM_BOT_TOKEN=123456:your-bot-token
TELEGRAM_ALLOWED_USER_ID=000000000

# --- infra ---
DATABASE_URL=sqlite+aiosqlite:///./komunalka.db
REDIS_URL=redis://localhost:6379/0

# --- LLM ---
# claude_code (default) uses the headless Claude Code CLI as a stateless LLM endpoint.
LLM_PROVIDER=claude_code
CLAUDE_BIN=claude

# --- matching / misc ---
# Comma-separated MCC codes treated as utility candidates (utilities, telecom).
UTILITY_MCCS=4900,4814
TZ=Europe/Kyiv

# Public base URL of this service (used by `komunalka register-mono-webhook`).
PUBLIC_BASE_URL=https://example.com

# DO NOT SET: ANTHROPIC_API_KEY — Claude Code would silently bill the API instead
# of using the Max subscription. The service strips it from the claude subprocess env.
